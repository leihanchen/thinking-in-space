Bootstrap: docker
From: nvidia/cuda:12.2.2-cudnn8-devel-ubuntu22.04

%labels
    Author leihan
    Description VSI-Bench evaluation runtime for thinking-in-space

%help
    Build image:
      apptainer build --fakeroot containers/vsibench_eval.sif vsibench_eval.def

    Run (example):
      apptainer exec --nv \
        --bind $PWD:/workspace \
        containers/vsibench_eval.sif \
        bash /workspace/evaluate_all_in_one.sh --model qwen_2p5_7b_instruct --benchmark vsibench

%environment
    export LC_ALL=C
    export LANG=C
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1

%post
    set -e
    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        python3-dev \
        git \
        ffmpeg \
        libgl1 \
        libglib2.0-0 \
        ca-certificates
    rm -rf /var/lib/apt/lists/*

    python3 -m pip install --upgrade pip setuptools wheel

%files
    . /opt/thinking-in-space

%post
    set -e
    cd /opt/thinking-in-space

    # Pin PyTorch to a CUDA 12.x wheel line compatible with typical CC driver stacks.
    # Without this, pip may resolve a newer CUDA 13 wheel that cannot initialize on CUDA 12.8 drivers.
    python3 -m pip install --no-cache-dir \
        --index-url https://download.pytorch.org/whl/cu124 \
        torch==2.6.0 torchvision==0.21.0 torchaudio==2.6.0

    # Follow README installation order exactly.
    python3 -m pip install -e ./transformers
    python3 -m pip install -e .
    python3 -m pip install "s2wrapper@git+https://github.com/bfshi/scaling_on_scales"
    python3 -m pip install deepspeed

    # Extra runtime package used by some Qwen VL pipelines.
    python3 -m pip install qwen-vl-utils

%runscript
    exec "$@"
